# ============================================================================
# Lanbel — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# ============================================================================

# --- App ---
NEXT_PUBLIC_APP_NAME="Lanbel"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (MongoDB Atlas) ---
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lanbel?retryWrites=true&w=majority"

# --- Auth / JWT ---
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="NQm8Yv4rX2Lk9Wp7Zs1Fd6Jt3Bn5Pc8Ha0Er9Qu2Mv7Cx4Ty1Rg"
JWT_REFRESH_SECRET="kP5xNz8Qw2Vm7Yc1Hs9Le4Fa0Dt6Rb3Ju8Xi5Mo1Gv9Ap2Kn7Sd"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
# Secret used to sign email-verification & password-reset tokens
AUTH_TOKEN_SECRET="bR8mXa2Qp7Vz5Hs9Nt1Ke4Yw6Lc0Df3Ju8Gi2Mo9Cr7Px4Tn5Sv"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="lanbel"

# --- Brevo (Email) ---
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="no-reply@lanbel.com"
BREVO_SENDER_NAME="Lanbel"

# --- Razorpay ---
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"

# --- Security ---
# Comma-separated list of allowed origins for CORS / CSRF checks
ALLOWED_ORIGINS="http://localhost:3000"

# --- Admin bootstrap (used by scripts/seed.ts) ---
SEED_ADMIN_EMAIL="admin@lanbel.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
